# ── MongoDB Atlas ────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/zanchi?retryWrites=true&w=majority

# ── 이메일 발송 (nodemailer, SMTP) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="잔치 리크루팅 <your-sender@gmail.com>"

# 관리자 알림 수신 이메일 (최대 4개, 쉼표 구분). 서버가 Settings 문서를 처음 만들 때만 사용됩니다.
# 이후에는 /admin/mypage 에서 DB 값을 직접 수정합니다.
ADMIN_EMAILS=editor1@example.com,editor2@example.com,editor3@example.com

# ── 관리자 로그인 ─────────────────────────────────────
ADMIN_MASTER_PASSWORD=tlschsxkaxka2026!
JWT_SECRET=change-this-to-a-long-random-string

# 주의: 프론트엔드와 백엔드 API가 이제 같은 Next.js 프로젝트(같은 origin)에 있으므로
# 예전의 FRONTEND_URL / CORS / NEXT_PUBLIC_API_BASE_URL 설정은 더 이상 필요하지 않습니다.
